# NETA AI — Environment Variables Template
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to version control — it is gitignored.
#
# Generate secrets:
#   SECRET_KEY         → python -c "import secrets; print(secrets.token_hex(32))"
#   POSTGRES_PASSWORD  → python -c "import secrets; print(secrets.token_urlsafe(32))"
#   REDIS_PASSWORD     → python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=netaai_prod
POSTGRES_USER=netaai_app
POSTGRES_PASSWORD=CHANGE_ME_MIN_32_CHARS

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_MIN_32_CHARS

# ── JWT Security ────────────────────────────────────────────────────────────
# Must be 64+ hex chars (openssl rand -hex 32 or secrets.token_hex(32))
SECRET_KEY=CHANGE_ME_RUN_python_secrets_token_hex_32

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── CORS ────────────────────────────────────────────────────────────────────
# Dev: include Vite ports.  Production: restrict to your HTTPS domain only.
# Example prod: ALLOWED_ORIGINS=["https://app.yourdomain.in"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5176","http://127.0.0.1:5176","https://app.netaai.in"]

# ── WhatsApp Business API (Meta Cloud API) ───────────────────────────────────
# Obtain from: Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
# Set this BEFORE registering the webhook URL in Meta Developer Console.
# Use any strong random string; must match what you enter in Meta's webhook form.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_STRONG_RANDOM_STRING
