# Frontend production build environment
# Loaded automatically by Vite when running: npm run build
#
# Leave VITE_API_URL empty so all /api calls use relative paths.
# nginx serves the frontend and proxies /api → backend on the same origin.
# This means the build works for ANY domain without being rebuilt per-domain.
#
# To pin to an explicit domain instead:
#   VITE_API_URL=https://app.netaai.in
VITE_API_URL=
