# NETA.AI — Production Environment Template
# ============================================================
# Copy this file to .env and fill in all CHANGE_ME values.
# NEVER commit .env to version control.
#
# Generate secrets (run on any machine with Python 3):
#   SECRET_KEY:        python3 -c "import secrets; print(secrets.token_hex(32))"
#   POSTGRES_PASSWORD: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   REDIS_PASSWORD:    python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   WEBHOOK_TOKEN:     python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# ============================================================

# ── Core Security ─────────────────────────────────────────────────────────────
# Must be exactly 64 hex characters (output of secrets.token_hex(32))
SECRET_KEY=CHANGE_ME_RUN_python3_secrets_token_hex_32

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=netaai_prod
POSTGRES_USER=netaai_app
# Minimum 32 characters
POSTGRES_PASSWORD=CHANGE_ME_MIN_32_CHARS

# ── Redis ─────────────────────────────────────────────────────────────────────
# Minimum 32 characters
REDIS_PASSWORD=CHANGE_ME_MIN_32_CHARS

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: restrict to your HTTPS domain only
# Replace app.netaai.in with your actual domain
ALLOWED_ORIGINS=["https://app.netaai.in"]

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────────────────
# Obtain from: Meta Developer Console → Your App → WhatsApp → API Setup
# Leave empty if not yet configured; WhatsApp features will be disabled.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
# Set this BEFORE registering the webhook URL in Meta Developer Console.
# Must match exactly what you enter in the Meta webhook verification field.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_STRONG_RANDOM_STRING

# ── Notes ─────────────────────────────────────────────────────────────────────
# POSTGRES_DB and POSTGRES_USER are set to defaults (netaai_prod / netaai_app).
# Change these only if you need non-standard database names.
#
# For local dev only, you can add localhost origins to ALLOWED_ORIGINS:
# ALLOWED_ORIGINS=["https://app.netaai.in","http://localhost:5173"]
