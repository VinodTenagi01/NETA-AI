# NETA AI — Environment Variables Template
# Copy to .env and fill in real values
# NEVER commit .env to version control

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://netaai_app:netaai_password@localhost:5432/netaai_prod
DATABASE_URL_SYNC=postgresql://netaai_app:netaai_password@localhost:5432/netaai_prod
POSTGRES_DB=netaai_prod
POSTGRES_USER=netaai_app
POSTGRES_PASSWORD=CHANGE_ME_32_CHARS_MINIMUM

# Redis
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_32_CHARS_MINIMUM

# JWT Security
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 key for PII fields)
PII_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MINIMUM_FOR_AES256

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","https://app.netaai.in"]

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# NLP Model
NLP_MODEL_PATH=/models/indic-bert-political

# App
DEBUG=false
CELERY_CONCURRENCY=4
TAG=latest
